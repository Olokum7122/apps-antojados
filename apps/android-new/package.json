{
  "name": "antojadosmx-android-v2",
  "version": "0.0.1",
  "description": "AntojadosMX Android V2 app built with Quasar + Capacitor",
  "productName": "AntojadosMX Android V2",
  "author": "AntojadosMX Team",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "build:android": "bash scripts/build-android.sh",
    "build:android:release": "bash scripts/build-android.sh --release",
    "build:android:bundle": "bash scripts/build-android.sh --bundle",
    "build:android:install": "bash scripts/build-android.sh --install",
    "scan:metadata": "node scripts/scan-ios-metadata.mjs",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@quasar/extras": "^1.18.0",
    "axios": "^1.18.1",
    "quasar": "^2.20.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@quasar/app-vite": "^2.6.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.14.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
