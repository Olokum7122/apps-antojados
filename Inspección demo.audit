{"type":"test-group","name":"Inspección demo","description":"Estos son ejemplos de pruebas que demuestran la funcionalidad y estructura de las inspecciones.","tests":[{"type":"test-group","name":"Niveles del resultado","description":"Estos son todos los distintos niveles de resultados de las pruebas.","tests":[{"type":"test-case","name":"level-pass","description":"Así se ve el resultado de una prueba aprobada y sin datos.","test":"function() {\n    return {level: \"pass\"};\n}"},{"type":"test-case","name":"level-warn","description":"Así se ve el resultado de una prueba con advertencia y sin datos.","test":"function() {\n    return {level: \"warn\"};\n}"},{"type":"test-case","name":"level-fail","description":"Así se ve el resultado de una prueba fallida y sin datos.","test":"function() {\n    return {level: \"fail\"};\n}"},{"type":"test-case","name":"level-error","description":"Así se ve el resultado de una prueba con error y sin datos.","test":"function() {\n    return {level: \"error\"};\n}"},{"type":"test-case","name":"level-unsupported","description":"Así se ve el resultado de una prueba no compatible y sin datos.","test":"function() {\n    return {level: \"unsupported\"};\n}"}]},{"type":"test-group","name":"Datos del resultado","description":"Estos son ejemplos de pruebas que demuestran los distintos tipos de datos que se pueden devolver con el resultado de la prueba.","tests":[{"type":"test-case","name":"data-domNodes","description":"Este es un ejemplo de cómo se muestran los nodos DOM de resultados. Aprobará con el elemento <body>.","test":"function() {\n    return {level: \"pass\", domNodes: [document.body]};\n}"},{"type":"test-case","name":"data-domAttributes","description":"Este es un ejemplo de cómo se muestran los atributos DOM de resultados resaltados en cualquier nodo DOM devuelto. Pasará con todos los elementos que incluyen un atributo id.","test":"function() {\n    return {level: \"pass\", domNodes: Array.from(document.querySelectorAll(\"[id]\")), domAttributes: [\"id\"]};\n}"},{"type":"test-case","name":"data-errors","description":"Este es un ejemplo de cómo se muestran los errores. El error se detectó de forma manual, pero los errores de ejecución aparecerán de la misma manera.","test":"function() {\n    throw Error(\"this error was thrown from inside the audit test code.\");\n}"},{"type":"test-case","name":"data-custom","description":"Este es un ejemplo de cómo se muestran datos de resultados personalizados.","supports":3,"test":"function() {\n    return {level: \"pass\", a: 1, b: [2], c: {key: 3}};\n}"}]},{"type":"test-group","name":"Datos expuestos especialmente","description":"Estos son ejemplos de pruebas que demuestran cómo usar WebInspectorAudit para acceder a información que no está disponible para JavaScript normalmente.","supports":1,"tests":[{"type":"test-group","name":"Accesibilidad","description":"Estos son ejemplos de pruebas que demuestran cómo usar WebInspectorAudit.Accessibility para obtener información sobre el árbol de accesibilidad.","supports":1,"tests":[{"type":"test-case","name":"getElementsByComputedRole","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getElementsByComputedRole para buscar elementos que cuentan con una función generada de “enlace”.","supports":1,"test":"function() {\n    return {level: \"pass\", domNodes: WebInspectorAudit.Accessibility.getElementsByComputedRole(\"link\"), domAttributes: [\"role\"]};\n}"},{"type":"test-case","name":"getActiveDescendant","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getActiveDescendant para buscar cualquier elemento que cumpla con los criterios del descendiente activo (“aria-activedescendant”) del elemento <body>, si los hay.","supports":1,"test":"function() {\n    let result = {level: \"pass\"};\n    let activeDescendant = WebInspectorAudit.Accessibility.getActiveDescendant(document.body);\n    if (activeDescendant)\n        result.domNodes = [activeDescendant];\n    return result;\n}"},{"type":"test-case","name":"getChildNodes","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getChildNodes para buscar nodos inferiores del elemento <body> en el árbol de accesibilidad.","supports":1,"test":"function() {\n    let childNodes = WebInspectorAudit.Accessibility.getChildNodes(document.body);\n    return {level: \"pass\", domNodes: childNodes || []};\n}"},{"type":"test-case","name":"getComputedProperties","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getComputedProperties para buscar una variedad de información de accesibilidad sobre el elemento <body>.","supports":3,"test":"function() {\n    let domAttributes = [\"alt\", \"aria-atomic\", \"aria-busy\", \"aria-checked\", \"aria-current\", \"aria-disabled\", \"aria-expanded\", \"aria-haspopup\", \"aria-hidden\", \"aria-invalid\", \"aria-label\", \"aria-labelledby\", \"aria-level\", \"aria-live\", \"aria-pressed\", \"aria-readonly\", \"aria-relevant\", \"aria-required\", \"aria-selected\", \"role\", \"title\"].filter((attribute) => document.body.hasAttribute(attribute));\n    let computedProperties = WebInspectorAudit.Accessibility.getComputedProperties(document.body);\n    return {level: \"pass\", domNodes: [document.body], domAttributes, ...(computedProperties || {})};\n}"},{"type":"test-case","name":"getControlledNodes","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getControlledNodes para buscar todos los nodos controlados (“aria-controls”) por el elemento <body>, si los hay.","supports":1,"test":"function() {\n    let controlledNodes = WebInspectorAudit.Accessibility.getControlledNodes(document.body);\n    return {level: \"pass\", domNodes: controlledNodes || []};\n}"},{"type":"test-case","name":"getFlowedNodes","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getFlowedNodes para buscar todos los nodos enviados (“aria-flowto”) del elemento <body>, si los hay.","supports":1,"test":"function() {\n    let flowedNodes = WebInspectorAudit.Accessibility.getFlowedNodes(document.body);\n    return {level: \"pass\", domNodes: flowedNodes || []};\n}"},{"type":"test-case","name":"getMouseEventNode","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getMouseEventNode para buscar el nodo que administraría los eventos del mouse del elemento <body>, si aplica.","supports":1,"test":"function() {\n    let result = {level: \"pass\"};\n    let mouseEventNode = WebInspectorAudit.Accessibility.getMouseEventNode(document.body);\n    if (mouseEventNode)\n        result.domNodes = [mouseEventNode];\n    return result;\n}"},{"type":"test-case","name":"getOwnedNodes","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getOwnedNodes para buscar todos los nodos que son propiedad (“aria-owns”) del elemento <body>, si los hay.","supports":1,"test":"function() {\n    let ownedNodes = WebInspectorAudit.Accessibility.getOwnedNodes(document.body);\n    return {level: \"pass\", domNodes: ownedNodes || []};\n}"},{"type":"test-case","name":"getParentNode","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getParentNode para buscar el nodo superior del elemento <body> en el árbol de accesibilidad.","supports":1,"test":"function() {\n    let result = {level: \"pass\"};\n    let parentNode = WebInspectorAudit.Accessibility.getParentNode(document.body);\n    if (parentNode)\n        result.domNodes = [parentNode];\n    return result;\n}"},{"type":"test-case","name":"getSelectedChildNodes","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getSelectedChildNodes para buscar todos los nodos inferiores seleccionados (“aria-selected”) del elemento <body> en el árbol de accesibilidad.","supports":1,"test":"function() {\n    let selectedChildNodes = WebInspectorAudit.Accessibility.getSelectedChildNodes(document.body);\n    return {level: \"pass\", domNodes: selectedChildNodes || []};\n}"}]},{"type":"test-group","name":"DOM","description":"Estos son ejemplos de pruebas que demuestran cómo usar WebInspectorAudit.DOM para obtener información sobre los nodos DOM.","supports":1,"tests":[{"type":"test-case","name":"hasEventListeners","description":"Este es un ejemplo de prueba de usa WebInspectorAudit.Accessibility.hasEventListeners para buscar datos que indican si el elemento <body> cuenta con receptores de cualquier evento.","supports":3,"test":"function() {\n    let domAttributes = Array.from(document.body.attributes).filter((attribute) => attribute.name.startsWith(\"on\"));\n    return {level: \"pass\", domNodes: [document.body], domAttributes, hasEventListeners: WebInspectorAudit.DOM.hasEventListeners(document.body)};\n}"},{"type":"test-case","name":"hasEventListeners-click","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.hasEventListenersClick para buscar datos que indican si el elemento <body> cuenta con receptores de eventos de clic.","supports":3,"test":"function() {\n    let domAttributes = [\"onclick\"].filter((attribute) => document.body.hasAttribute(attribute));\n    return {level: \"pass\", domNodes: [document.body], domAttributes, hasClickEventListener: WebInspectorAudit.DOM.hasEventListeners(document.body, \"click\")};\n}"}]},{"type":"test-group","name":"Recursos","description":"Estos son ejemplos de pruebas que demuestran cómo usar WebInspectorAudit.Resources para obtener información sobre los recursos cargados.","supports":2,"tests":[{"type":"test-case","name":"getResources","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getResources para buscar información básica sobre cada recurso.","supports":3,"test":"function() {\n    return {level: \"pass\", resources: WebInspectorAudit.Resources.getResources()};\n}"},{"type":"test-case","name":"getResourceContent","description":"Este es un ejemplo de prueba que usa WebInspectorAudit.Accessibility.getResourceContent para buscar el contenido del recurso principal.","supports":3,"test":"function() {\n    let resources = WebInspectorAudit.Resources.getResources();\n    let mainResource = resources.find((resource) => resource.url === window.location.href);\n    return {level: \"pass\", mainResource, resourceContent: WebInspectorAudit.Resources.getResourceContent(mainResource.id)};\n}"}]}]},{"type":"test-case","name":"unsupported","description":"Este es un ejemplo de una prueba que no se ejecutará porque no es compatible.","supports":5,"test":"function() {\n    throw Error(\"this test should not be supported.\");\n}"}]}